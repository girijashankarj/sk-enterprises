# Prototype: shared mock fixtures. Set to false when API is integrated.
EXPO_PUBLIC_USE_MOCK_API=true

# Optional: which role / tab to prefer when debugging (see .vscode/launch.json)
# EXPO_PUBLIC_INITIAL_ROLE=ADMIN
# EXPO_PUBLIC_INITIAL_ROLE=EMPLOYEE

# Optional: workshop map location for mobile location tab
# EXPO_PUBLIC_WORKSHOP_NAME=SK Enterprises
# EXPO_PUBLIC_WORKSHOP_LATITUDE=18.6298
# EXPO_PUBLIC_WORKSHOP_LONGITUDE=73.8478
# EXPO_PUBLIC_WORKSHOP_MAP_URL=https://www.google.com/maps?q=18.6298,73.8478
