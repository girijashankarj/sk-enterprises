# Prototype: use shared mock fixtures (no database). Set to false when API is wired.
VITE_USE_MOCK_API=true

# Backend base URL when VITE_USE_MOCK_API=false
VITE_API_BASE_URL=http://localhost:4000

# Public landing: POST contact form to API when base URL is set. Set false for mailto-only (e.g. GitHub Pages without API).
# VITE_PUBLIC_LEAD_CAPTURE=true

# Optional: GA4 (G-XXXXXXXX) and Google Search Console HTML verification content
# VITE_GA_MEASUREMENT_ID=
# VITE_GOOGLE_SITE_VERIFICATION=

# Google OAuth Web client ID (must match API GOOGLE_CLIENT_ID) when VITE_USE_MOCK_API=false
# VITE_GOOGLE_CLIENT_ID=

# Dev UI persona: admin (default) or employee — matches .vscode/launch.json
# VITE_DEV_ROLE=admin
# VITE_DEV_ROLE=employee

# Optional: workshop map location in web app
# VITE_WORKSHOP_NAME=SK Enterprises
# VITE_WORKSHOP_LATITUDE=18.6298
# VITE_WORKSHOP_LONGITUDE=73.8478
# VITE_WORKSHOP_MAP_URL=https://www.google.com/maps?q=18.6298,73.8478
# VITE_WORKSHOP_MAP_EMBED_URL=https://maps.google.com/maps?q=18.6298,73.8478&z=15&output=embed
